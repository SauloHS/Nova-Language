int main() {
    int sieve[1000001];
    int i = 0;
    while(i <= 1000000) {
        sieve[i] = 1;
        i = i + 1;
    }
    sieve[0] = 0;
    sieve[1] = 0;
    int p = 2;
    while(p * p <= 1000000) {
        if(sieve[p] == 1) then {
            int mult = p * p;
            while(mult <= 1000000) {
                sieve[mult] = 0;
                mult = mult + p;
            }
        }
        p = p + 1;
    }
    int n = 2;
    while(n <= 1000000) {
        if(sieve[n] == 1) then {
            print(n);
        }
        n = n + 1;
    }
    return 0;
}