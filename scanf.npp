#include <stdio.nh>

struct Point {
    x: i32;
    y: i32;
}

fn main() {
    let mut s: i32 = 0;
    std::print("Digite o valor de S");
    std::scanf("%d", &s);
    std::printf("O valor digitado foi: ");
    std::print(s);
    let point: Point = {
        x: 1,
        y: 2
    };
    std::printf("%d\n", point.x);   // 1
}