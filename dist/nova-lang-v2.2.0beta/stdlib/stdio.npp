#include <stdio.nh>
fn print(n: i32) {
    std::printf("%d\n", n);
}

fn print(n: f64) {
    std::printf("%f\n", n);
}

fn print(n: f32) {
    std::printf("%f\n", n as f32);
}

fn print(s: string) {
    std::printf("%s\n", s);
}

fn print(c: char) {
    std::printf("%c\n", c);
}

fn print(n: i64) {
    std::printf("%ld\n", n);
}